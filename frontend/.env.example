# Frontend — Variables de entorno para Vite
# Copia este archivo como .env y completa los valores
# Variables VITE_* se incrustan en el bundle — no pongas secretos críticos aquí

# URL del backend en Render (en producción)
# En desarrollo local: http://localhost:3001
VITE_API_URL=https://tu-backend.onrender.com

# Gemini AI (opcional — solo si llamas a Gemini directo desde el frontend)
VITE_GEMINI_API_KEY=
