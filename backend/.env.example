# Backend — Variables de entorno
# Copia este archivo como .env y completa los valores reales
# NUNCA subas .env al repositorio

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Gemini AI (opcional)
GEMINI_API_KEY=

# Express
PORT=3001

# CORS — separar múltiples orígenes con coma
# Ej: https://tu-app.vercel.app,http://localhost:5173
CORS_ORIGIN=https://tu-app.vercel.app,http://localhost:5173

# Entorno
NODE_ENV=production

# Nodemailer / SMTP Config
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
